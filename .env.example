# ── App ──────────────────────────────────────────────
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=INFO

# ── Datastores ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://factory:factory@localhost:5432/factorymind
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── LLM providers (leave blank to use deterministic mocks) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PRIMARY_LLM_MODEL=claude-sonnet-5
FALLBACK_LLM_MODEL=gpt-4o
JUDGE_LLM_MODEL=claude-haiku-4-5-20251001

# ── HuggingFace inference ────────────────────────────
HF_API_TOKEN=
HF_USE_MOCK=true

# ── Observability ────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# ── Integrations (blank = mock) ──────────────────────
JIRA_BASE_URL=https://factorymind.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=MAINT
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
PAGERDUTY_ROUTING_KEY=
SAP_BASE_URL=https://sap.factorymind.internal
SAP_API_KEY=
SENDGRID_API_KEY=
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# ── Auth ─────────────────────────────────────────────
AUTH0_DOMAIN=factorymind.us.auth0.com
AUTH0_AUDIENCE=https://api.factorymind.ai
JWT_SECRET_DEV=dev-insecure-secret-change-me

# ── AWS ──────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=factorymind-artifacts
